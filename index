<!DOCTYPE html>
<html lang="pt-br">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Pôsteres Congresso Brasileiro de Comportamento Motor - 2026</title>
    <style>
        body {
            font-family: sans-serif;
            text-align: center;
            /* Centraliza o texto e elementos inline */
            margin-top: 30px;
            /* Reduzi um pouco a margem superior */
        }

        .logo-container {
            display: flex;
            /* Habilita o Flexbox para alinhar os itens filhos */
            justify-content: center;
            /* Centraliza os itens horizontalmente */
            align-items: center;
            /* Centraliza os itens verticalmente (opcional, dependendo da altura das imagens) */
            margin-bottom: 20px;
            /* Espaço abaixo dos logos */
        }

        .logo {
            max-width: 45%;
            /* Ajusta a largura para ocupar menos da metade em telas lado a lado */
            height: auto;
            margin: 0 10px;
            /* Adiciona um espaço entre as imagens */
        }

        .link-button {
            display: block;
            margin: 10px auto;
            padding: 15px 30px;
            background-color: #f0f0f0;
            color: #333;
            text-decoration: none;
            border-radius: 5px;
            width: 80%;
            max-width: 300px;
        }

        h1 {
            margin-top: 30px;
            /* Adiciona espaço acima do título */
        }

        /* Media Query para telas com largura máxima de 600 pixels (telas de celular, geralmente) */
        @media (max-width: 600px) {
            .logo-container {
                flex-direction: column;
                /* Alinha os itens verticalmente em coluna */
                align-items: center;
                /* Centraliza os itens horizontalmente dentro da coluna */
            }

            .logo {
                max-width: 80%;
                /* Aumenta a largura para ocupar mais espaço na tela */
                margin: 10px 0;
                /* Adiciona margem superior e inferior para separação */
            }
        }
    </style>
</head>

<body>
    <div class="logo-container">
        <img src="GPeCAM_logo_2026.png" alt="Logo GPeCAM" class="logo">
    </div>
    <h1>Pôsteres<br>GPeCAM<br>CBCM 2026</h1>
    <a href="poster_Lais_CBCM_2026.pdf" class="link-button" target="_blank">Serafim & Moraes</a>
    <a href="https://sites.google.com/usp.br/gpecam" class="link-button" target="_blank">Site GPeCAM</a>
    <a href="https://www.instagram.com/grupo.gpecam?igsh=NXEyazM3Mmk5ZnF6" class="link-button"
        target="_blank">Instagram GPeCAM</a>
</body>

</html>
